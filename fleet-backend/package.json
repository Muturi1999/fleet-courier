{
  "name": "fleet-backend",
  "version": "0.1.0",
  "description": "Fleet Courier — multi-tenant NestJS API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
